#!name=Google Helpers (Local Wrapper)
#!desc=Wrap upstream Google helpers with %APPEND% MITM to avoid hostname override

[MITM]
hostname = %APPEND% www.google.*, www.google.com*

[Script]
google-endless = type=http-response,pattern=^https?:\/\/www\.google\..*\/search,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/master/endlessgoogle.js
google-captcha = type=http-response,pattern=^https:\/\/www\.google\.com(?:\.[a-z]+|)\/(?:search\?(?:|.+?&)q=|$),requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/NobyDa/Script/master/Surge/JS/Google_CAPTCHA.js
